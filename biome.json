{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noImplicitAnyLet": "off"
      },
      "correctness": {
        // Keep this OFF globally — Biome can't fully see Svelte template usage.
        "noUnusedVariables": "off",
        "noInvalidPositionAtImportRule": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    // ⚠️ IMPORTANT: Biome's Svelte support is EXPERIMENTAL (🟡) as of v2.4.
    //
    // It does NOT parse Svelte-specific syntax ({#if}, {#each}, etc.), so:
    //   - Imports used only in template markup get removed as "unused"
    //   - Variables referenced in {#each} / {#if} get renamed with _ prefix
    //   - This caused a full site outage (500 on every page) on 2026-02-24
    //
    // The Svelte team also does not recommend switching yet (Oct 2025).
    // See: https://biomejs.dev/internals/language-support/#html-super-languages-support
    //
    // When Biome Svelte support goes stable, remove this ignore and use
    // overrides instead (see docs for recommended rule disables).
    // Use `svelte-check` for Svelte-specific linting in the meantime.
    "ignore": ["*.svelte"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
